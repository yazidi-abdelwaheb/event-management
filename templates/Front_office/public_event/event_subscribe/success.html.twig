{% extends 'Front_office/base.html.twig' %}

{% block body %}
<style>
    :root {
        --primary-dark: #12121e;
        --card-bg: #1c1c2d;
        --accent-green: #2ecc71;
        --text-muted: #a0a0b0;
    }

    .success-wrapper {
        background: #f8f9fa;
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .success-card {
        background: #fff;
        border-radius: 15px;
        padding: 40px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        text-align: center;
        border: 1px solid rgba(255,255,255,0.05);
        animation: slideUp 0.6s ease-out;
    }

    /* Animation de l'icône Check */
    .checkmark-wrapper {
        width: 100px;
        height: 100px;
        margin: 0 auto 25px;
        position: relative;
    }

    .checkmark-circle {
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        stroke-width: 2;
        stroke-miterlimit: 10;
        stroke: #2ecc71;
        fill: none;
        animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    }

    .checkmark-check {
        transform-origin: 50% 50%;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
    }

    @keyframes stroke { 100% { stroke-dashoffset: 0; } }
    @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

    .ticket-info {
        background: #1a1a2e;
        border-radius: 16px;
        padding: 20px;
        margin: 25px 0;
        border: 1px dashed rgba(255,255,255,0.1);
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 0.95rem;
    }

    .info-label { color: #a0a0b0; }
    .info-value { color: #fff; font-weight: 600; }

.btn-download {
        background: linear-gradient(135deg, #6c5ce7, #a29bfe);
        color: white;
        padding: 16px;
        border-radius: 12px;
        display: block;
        text-decoration: none;
        font-weight: 700;
        transition: transform 0.2s;
        margin-bottom: 15px;
    }

    .btn-download:hover { transform: scale(1.02); color: #fff; }

    .back-link {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
    }
    .back-link:hover { color: #2ecc71; }
</style>

<div class="success-wrapper" id="successWrapper">
    <div class="success-card">
        <div class="checkmark-wrapper">
            <i class="bi bi-patch-check-fill" style="font-size: 60px;"></i>
        </div>

        <h1 class="fw-bold" style="color: #1a1a2e; font-size: 2rem;">Subscription Confirmed</h1>
        <p style="color: var(--text-muted);">Your registration for <strong>{{ event.title }}</strong> is confirmed.</p>

        <div class="ticket-info">
            <div class="info-row">
                <span class="info-label">Reference</span>
                <span class="info-value">#{{ sub.id|slice(0, 8)|upper }}</span>
            </div>
            <div class="info-row">
                <span class="info-label">Date</span>
                <span class="info-value">{{ event.start_date_time|date('d M Y') }}</span>
            </div>
            <div class="info-row">
                <span class="info-label">Location</span>
                <span class="info-value">{{ event.location }}</span>
            </div>
            <div class="info-row" style="margin-top: 10px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.05);">
                <span class="info-label">Amount Paid</span>
                <span class="info-value" style="color: var(--accent-green);">{{ event.price }} TND</span>
            </div>
        </div>

        <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 25px;">
            You will receive a confirmation email shortly with all the details. We look forward to seeing you at the event!
        </p>
        <div class="actions">
            <a href="{{ path('app_public_event_show', { id: event.id }) }}" class="btn-download w-100 py-3 fw-bold shadow-sm" style="border-radius: 12px; background-color: #1a1a2e;">
                <i class="fas fa-file-pdf" style="margin-right: 8px;"></i> 
                Back to event details
            </a>
            <a href="{{ path('app_public_event') }}" class="back-link">
                <i class="fas fa-arrow-left"></i> Back to Events
            </a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
<script>

    

   document.addEventListener("DOMContentLoaded", function () {
    confetti({
        particleCount: 1000,
        spread: 200,
        origin: { y: 0.5 },
        colors: ['#6c5ce7', '#2ecc71', '#ffffff']
    });
});
</script>
{% endblock %}