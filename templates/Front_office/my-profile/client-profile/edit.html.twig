{% extends 'Front_office/my-profile/base.html.twig' %}

{% block profile_content %}
<style>
    .form-control:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    }
    .section-card {
        transition: transform 0.2s ease;
    }
    .btn-save {
        transition: all 0.3s ease;
        font-weight: 500;
    }
    .btn-save:hover {
        transform: translateY(-1px);
        filter: brightness(1.1);
    }
</style>

<div class="container" >
    
    {# Alertes Flash #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : 'success' }} border-0 shadow-sm d-flex align-items-center gap-3 rounded-4 mb-4 animate__animated animate__fadeIn">
                <i class="bi bi-{{ label == 'error' ? 'exclamation-circle' : 'check-circle' }}-fill fs-5"></i>
                <div>{{ message }}</div>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row g-4">
        
        {# 1. Infos Personnelles #}
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 section-card">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:40px; height:40px; background:#eff6ff;">
                            <i class="bi bi-person-badge text-primary fs-5"></i>
                        </div>
                        <h5 class="mb-0 fw-bold text-dark">Personal Information</h5>
                    </div>

                    <form method="post">
                        <input type="hidden" name="section" value="info">
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">First Name</label>
                                <input type="text" name="first_name" value="{{ user.firstName }}" class="form-control form-control-lg rounded-3 fs-6" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Last Name</label>
                                <input type="text" name="last_name" value="{{ user.lastName }}" class="form-control form-control-lg rounded-3 fs-6" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold text-muted text-uppercase">Email Address</label>
                                <input type="email" name="email" value="{{ user.email }}" class="form-control form-control-lg rounded-3 fs-6" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-save px-4 py-2 rounded-3">
                            Save Profile
                        </button>
                    </form>
                </div>
            </div>
        </div>

        {# 2. Avatar #}
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 section-card">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:40px; height:40px; background:#f5f3ff;">
                            <i class="bi bi-camera text-purple fs-5" style="color:#7c3aed;"></i>
                        </div>
                        <h5 class="mb-0 fw-bold text-dark">Profile Picture</h5>
                    </div>

                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" name="section" value="avatar">
                        <div class="d-flex flex-column flex-md-row align-items-center gap-4">
                            <div class="position-relative">
                                {% if user.avatar %}
                                    <img src="/uploads/avatars/{{ user.avatar }}" class="rounded-circle shadow-sm" style="width:100px; height:100px; object-fit:cover; border:4px solid #fff;">
                                {% else %}
                                    <div class="rounded-circle shadow-sm d-flex align-items-center justify-content-center text-white fw-bold" 
                                         style="width:100px; height:100px; font-size:32px; background: linear-gradient(135deg, #2563eb, #7c3aed);">
                                        {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                    </div>
                                {% endif %}
                            </div>
                            
                            <div class="flex-grow-1 w-100">
                                <input type="file" name="avatar" class="form-control rounded-3 mb-2" accept="image/*">
                                <p class="text-muted small mb-0">Recommended: Square image, max 2MB (JPG, PNG, WebP)</p>
                            </div>

                            <button type="submit" class="btn btn-save text-white px-4 py-2 rounded-3 flex-shrink-0" style="background:#7c3aed;">
                                Update Photo
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# 3. Sécurité #}
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 section-card">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:40px; height:40px; background:#fff7ed;">
                            <i class="bi bi-shield-lock text-orange fs-5" style="color:#ea580c;"></i>
                        </div>
                        <h5 class="mb-0 fw-bold text-dark">Change Password</h5>
                    </div>

                    <form method="post">
                        <input type="hidden" name="section" value="password">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Current Password</label>
                            <input type="password" name="current_password" class="form-control rounded-3" required>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">New Password</label>
                                <input type="password" name="new_password" class="form-control rounded-3" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Confirm New Password</label>
                                <input type="password" name="confirm_password" class="form-control rounded-3" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-save text-white px-4 py-2 rounded-3" style="background:#ea580c;">
                            Update Password
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}