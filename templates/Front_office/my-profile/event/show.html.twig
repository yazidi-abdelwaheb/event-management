{% extends 'Front_office/my-profile/base.html.twig' %}

{% block title %}{{ event.getTitle() }} — EventManage{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .show-hero {
        background: #1a1a2e;
        padding: 2.5rem 1.5rem;
    }

    .info-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 1.75rem;
    }

    .info-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid #f3f4f6;
    }
    .info-row:last-child { border-bottom: none; }

    .info-icon {
        width: 36px; height: 36px;
        background: #f8f7f4;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .info-label {
        font-size: 11px;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 0 0 2px;
    }

    .info-value {
        font-size: 14px;
        font-weight: 600;
        color: #1a1a2e;
        margin: 0;
    }

    .stat-box {
        background: #f8f7f4;
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
        flex: 1;
    }

    .subscribers-bar {
        height: 6px;
        background: #e5e7eb;
        border-radius: 6px;
        overflow: hidden;
        margin-top: 6px;
    }
    .subscribers-fill {
        height: 100%;
        background: #1a1a2e;
        border-radius: 6px;
    }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .table-wrapper {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        overflow: hidden;
    }

    .sub-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .sub-table thead tr {
        background: #f8f7f4;
        border-bottom: 1px solid #e5e7eb;
    }

    .sub-table thead th {
        padding: 12px 16px;
        font-size: 11px;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: left;
        white-space: nowrap;
    }

    .sub-table tbody tr {
        border-bottom: 1px solid #f3f4f6;
        transition: background 0.15s;
    }
    .sub-table tbody tr:last-child { border-bottom: none; }
    .sub-table tbody tr:hover { background: #fafafa; }

    .sub-table tbody td {
        padding: 12px 16px;
        color: #374151;
        vertical-align: middle;
    }

    .avatar-sm {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: #1a1a2e;
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 700; color: white;
        flex-shrink: 0;
    }

    .btn-export {
        background: #1a1a2e;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        padding: 8px 16px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        transition: opacity 0.2s;
    }
    .btn-export:hover { opacity: 0.85; color: white; }

    .btn-export-csv {
        background: #3B6D11;
    }

    .btn-back {
        background: #f3f4f6;
        color: #374151;
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        padding: 8px 16px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background 0.2s;
    }
    .btn-back:hover { background: #e5e7eb; color: #1a1a2e; }

    .breadcrumb-item a {
        color: rgba(255,255,255,0.6);
        text-decoration: none; font-size: 13px;
    }
    .breadcrumb-item a:hover { color: white; }
    .breadcrumb-item.active { color: rgba(255,255,255,0.9); font-size: 13px; }

    .search-input {
        padding: 8px 12px 8px 36px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: 13px;
        background: #fafafa;
        outline: none;
        width: 220px;
    }
    .search-input:focus {
        border-color: #1a1a2e;
        background: white;
    }

    @media print {
        .no-print { display: none !important; }
        .table-wrapper { border: none; }
    }
</style>
{% endblock %}

{% block profile_content %}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h2 style="font-size:18px; font-weight:700; color:#1a1a2e; margin:0 0 4px;">
            {{ event.getTitle() }}
        </h2>
        <p style="font-size:13px; color:#6b7280; margin:0;">
            Event details and subscribers
        </p>
    </div>
    <div class="d-flex gap-2 no-print">
        <a href="{{ path('app_event_index') }}" class="btn-back">
            <i class="bi bi-arrow-left" style="font-size:12px;"></i>
            Back
        </a>
        <a href="{{ path('app_event_edit', {id: event.getId()}) }}" 
           class="btn-export" style="background:#534AB7;">
            <i class="bi bi-pencil" style="font-size:12px;"></i>
            Edit
        </a>
    </div>
</div>

<div class="row g-4">

    <div class="col-lg-5">

        <div style="border-radius:14px; overflow:hidden; margin-bottom:1rem;
                    background:#1a1a2e; height:200px; position:relative;
                    display:flex; align-items:center; justify-content:center;">
            {% if event.getImage() %}
                <img src="{{ asset('uploads/events/' ~ event.getImage()) }}"
                     alt="{{ event.getTitle() }}"
                     style="width:100%; height:100%; object-fit:cover;">
            {% else %}
                <i class="bi bi-calendar-event"
                   style="font-size:48px; color:rgba(255,255,255,0.15);"></i>
            {% endif %}

            
                <span style="
                    position:absolute;
                    top:12px;
                    left:12px;
                    background: {{ event.status.color() }};
                    color: {{ event.status.textColor() }};
                    font-size:11px;
                    font-weight:700;
                    padding:4px 12px;
                    border-radius:20px;
                ">
                    <i class="bi bi-circle-fill me-1" style="font-size:7px;"></i>
                    {{ event.status.label() }}
                </span>
            
        </div>

        <div class="d-flex gap-2 mb-3">
            <div class="stat-box">
                <p style="font-size:22px; font-weight:700; color:#1a1a2e; margin:0;">
                    {{ event.getSubscribedCount() }}
                </p>
                <p style="font-size:11px; color:#6b7280; margin:0;">Subscribers</p>
            </div>
            <div class="stat-box">
                <p style="font-size:22px; font-weight:700; color:#1a1a2e; margin:0;">
                    {{ event.getCapacity() }}
                </p>
                <p style="font-size:11px; color:#6b7280; margin:0;">Capacity</p>
            </div>
            <div class="stat-box">
                <p style="font-size:22px; font-weight:700;
                           color:{{ event.getPrice() == 0 ? '#3B6D11' : '#1a1a2e' }}; margin:0;">
                    {{ event.getPrice() == 0 ? 'Free' : event.getPrice()|number_format(0) }}
                </p>
                <p style="font-size:11px; color:#6b7280; margin:0;">
                    {{ event.getPrice() == 0 ? 'Entry' : 'TND' }}
                </p>
            </div>
        </div>

        <div class="info-card mb-3" style="padding:1rem 1.25rem;">
            <div class="d-flex justify-content-between mb-1">
                <span style="font-size:12px; color:#6b7280;">Capacity filled</span>
                <span style="font-size:12px; font-weight:700; color:#1a1a2e;">
                    {% set pct = event.getCapacity() > 0
                        ? ((event.getSubscribedCount() / event.getCapacity()) * 100)|round
                        : 0 %}
                    {{ pct }}%
                </span>
            </div>
            <div class="subscribers-bar">
                <div class="subscribers-fill" style="width:{{ pct }}%;
                     background:{{ pct >= 90 ? '#dc2626' : (pct >= 60 ? '#f97316' : '#1a1a2e') }};"></div>
            </div>
            <p style="font-size:11px; color:#9ca3af; margin:6px 0 0;">
                {{ event.getCapacity() - event.getSubscribedCount() }} spots remaining
            </p>
        </div>

        <div class="info-card">

            <div class="info-row">
                <div class="info-icon">
                    <i class="bi bi-calendar3" style="font-size:14px; color:#6b7280;"></i>
                </div>
                <div>
                    <p class="info-label">Start</p>
                    <p class="info-value">
                        {{ event.getStartDateTime()|date('D d M Y · H:i') }}
                    </p>
                </div>
            </div>

            {% if event.getEndDateTime() %}
            <div class="info-row">
                <div class="info-icon">
                    <i class="bi bi-clock" style="font-size:14px; color:#6b7280;"></i>
                </div>
                <div>
                    <p class="info-label">End</p>
                    <p class="info-value">
                        {{ event.getEndDateTime()|date('D d M Y · H:i') }}
                    </p>
                </div>
            </div>
            {% endif %}

            <div class="info-row">
                <div class="info-icon">
                    <i class="bi bi-geo-alt" style="font-size:14px; color:#6b7280;"></i>
                </div>
                <div>
                    <p class="info-label">Location</p>
                    <p class="info-value">{{ event.getLocation() }}</p>
                </div>
            </div>

            <div class="info-row">
                <div class="info-icon">
                    <i class="bi bi-tag" style="font-size:14px; color:#6b7280;"></i>
                </div>
                <div>
                    <p class="info-label">Category</p>
                    <p class="info-value">{{ event.getCategory().getLabel() }}</p>
                </div>
            </div>

            <div class="info-row">
                <div class="info-icon">
                    <i class="bi bi-calendar-plus" style="font-size:14px; color:#6b7280;"></i>
                </div>
                <div>
                    <p class="info-label">Created</p>
                    <p class="info-value">{{ event.getCreatedAt()|date('d M Y') }}</p>
                </div>
            </div>

            <div class="info-row">
                <div class="info-icon">
                    <i class="bi bi-text-paragraph" style="font-size:14px; color:#6b7280;"></i>
                </div>
                <div>
                    <p class="info-label">Description</p>
                    <p style="font-size:13px; color:#374151; margin:0; line-height:1.6;">
                        {{ event.getDescription()|nl2br }}
                    </p>
                </div>
            </div>

        </div>
    </div>

    <div class="col-lg-7">

        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 no-print">
            <div class="section-title" style="margin:0;">
                <i class="bi bi-people" style="font-size:16px;"></i>
                Subscribers
                <span style="background:#f3f4f6; color:#6b7280; font-size:11px;
                             font-weight:700; padding:2px 10px; border-radius:10px;">
                    {{ subscribers|length }}
                </span>
            </div>
            <div class="d-flex gap-2 align-items-center flex-wrap">

                <div style="position:relative;">
                    <i class="bi bi-search"
                       style="position:absolute; left:10px; top:50%; transform:translateY(-50%);
                              font-size:12px; color:#9ca3af;"></i>
                    <input type="text"
                           id="search-input"
                           class="search-input"
                           placeholder="Search subscriber..."
                           oninput="filterTable(this.value)">
                </div>

                <button onclick="exportCSV()" class="btn-export btn-export-csv">
                    <i class="bi bi-filetype-csv" style="font-size:13px;"></i>
                    Export CSV
                </button>

            </div>
        </div>

        {% if subscribers|length > 0 %}

            <div class="table-wrapper">
                <table class="sub-table" id="subscribers-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Subscriber</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Registered on</th>
                            <th class="no-print">Ticket</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for sub in subscribers %}
                            <tr>
                                <td style="color:#9ca3af; font-weight:600;">
                                    {{ '%03d'|format(loop.index) }}
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-sm">
                                            {{ sub.getFullName()|first|upper }}
                                        </div>
                                        <span style="font-weight:600; color:#1a1a2e;">
                                            {{ sub.getFullName() }}
                                        </span>
                                    </div>
                                </td>
                                <td style="color:#6b7280;">{{ sub.getEmail() }}</td>
                                <td style="color:#6b7280;">{{ sub.getPhone() }}</td>
                                <td style="color:#6b7280;">
                                    {{ sub.getCreatedAt()|date('d M Y · H:i') }}
                                </td>
                                <td class="no-print">
                                    <span style="background:#f3f4f6; color:#374151; font-size:11px;
                                                 font-weight:700; padding:3px 10px; border-radius:6px;
                                                 font-family:monospace; letter-spacing:1px;">
                                        #{{ '%06d'|format(sub.getId()) }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div id="no-result"
                 style="display:none; text-align:center; padding:3rem 1rem;
                        background:white; border:1px solid #e5e7eb; border-radius:16px; margin-top:4px;">
                <i class="bi bi-search" style="font-size:32px; color:#d1d5db; display:block; margin-bottom:8px;"></i>
                <p style="font-size:14px; color:#6b7280; margin:0;">No subscriber found.</p>
            </div>

        {% else %}

            <div style="text-align:center; padding:4rem 2rem; background:white;
                        border:1px solid #e5e7eb; border-radius:16px;">
                <div style="width:72px; height:72px; background:#f3f4f6; border-radius:50%;
                            display:flex; align-items:center; justify-content:center; margin:0 auto 1.25rem;">
                    <i class="bi bi-people" style="font-size:32px; color:#9ca3af;"></i>
                </div>
                <h3 style="font-size:17px; font-weight:600; color:#374151; margin:0 0 8px;">
                    No subscribers yet
                </h3>
                <p style="font-size:14px; color:#6b7280; margin:0;">
                    Nobody has registered for this event yet.
                </p>
            </div>

        {% endif %}

    </div>
</div>

<script>
function filterTable(query) {
    const rows  = document.querySelectorAll('#subscribers-table tbody tr');
    const lower = query.toLowerCase().trim();
    let found   = 0;

    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        const show = text.includes(lower);
        row.style.display = show ? '' : 'none';
        if (show) found++;
    });

    document.getElementById('no-result').style.display = found === 0 ? 'block' : 'none';
}

function exportCSV() {
    const rows    = document.querySelectorAll('#subscribers-table tbody tr');
    const headers = ['#', 'Full Name', 'Email', 'Phone', 'Registered On', 'Ticket ID'];
    const lines   = [headers.join(',')];

    rows.forEach((row, i) => {
        if (row.style.display === 'none') return;
        const cells = row.querySelectorAll('td');
        const line  = [
            (i + 1),
            '"' + (cells[1]?.querySelector('span:last-child')?.textContent?.trim() ?? '') + '"',
            '"' + (cells[2]?.textContent?.trim() ?? '') + '"',
            '"' + (cells[3]?.textContent?.trim() ?? '') + '"',
            '"' + (cells[4]?.textContent?.trim() ?? '') + '"',
            '"' + (cells[5]?.textContent?.trim() ?? '') + '"',
        ];
        lines.push(line.join(','));
    });

    const csv  = lines.join('\n');
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = '{{ event.getTitle()|e('js') }}_{{ "now"|date("Ymd") }}.csv';
    a.click();
    URL.revokeObjectURL(url);
}
</script>

{% endblock %}