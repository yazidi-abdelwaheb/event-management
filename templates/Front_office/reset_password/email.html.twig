<!DOCTYPE html>

<body style="margin:0; padding:0; background:#f8f7f4; font-family: 'Segoe UI', Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f8f7f4; padding: 40px 16px;">
    <tr><td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:16px; overflow:hidden; border: 1px solid #e5e7eb;">

        
        <tr>
          <td style="background:#1a1a2e; padding: 24px 32px; display:flex; align-items:center; gap:12px;">
            <span style="color:white; font-size:16px; font-weight:700; letter-spacing:0.3px;">
              🔐 Event Management
            </span>
          </td>
        </tr>

        
        <tr>
          <td style="padding: 40px 32px 32px;">

           
            <div style="width:60px; height:60px; background:#fef3c7; border:2px solid #fde68a;
                        border-radius:50%; margin-bottom:24px;
                        display:table-cell; vertical-align:middle; text-align:center;">
              <span style="font-size:26px; line-height:60px; display:block;">🔑</span>
            </div>

            <h1 style="font-size:22px; font-weight:700; color:#1a1a2e; margin:0 0 8px;">
              Reset your password
            </h1>
            <p style="font-size:15px; color:#6b7280; margin:0 0 28px; line-height:1.6;">
              We received a request to reset the password for your account.
              Click the button below to choose a new password.
            </p>

            <a href="{{ url('app_reset_password', {token: resetToken.token}) }}"
               style="display:inline-block; background:#1a1a2e; color:white; text-decoration:none;
                      font-size:15px; font-weight:600; padding:14px 32px;
                      border-radius:8px; margin-bottom:28px; letter-spacing:0.3px;">
              Reset my password →
            </a>

            <div style="background:#fef3c7; border:1px solid #fde68a; border-radius:8px;
                        padding:12px 16px; margin-bottom:24px;
                        display:table; width:100%; box-sizing:border-box;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="width:20px; vertical-align:top; padding-top:1px;">
                    ⏰
                  </td>
                  <td style="font-size:13px; color:#92400e; line-height:1.5; padding-left:8px;">
                    This link will expire in
                    <strong style="color:#78350f;">
                      {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}
                    </strong>.
                    After that, you'll need to request a new one.
                  </td>
                </tr>
              </table>
            </div>

            <div style="background:#f0f9ff; border:1px solid #bae6fd; border-radius:8px;
                        padding:12px 16px; margin-bottom:24px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="width:20px; vertical-align:top; padding-top:1px;">ℹ️</td>
                  <td style="font-size:13px; color:#0369a1; line-height:1.5; padding-left:8px;">
                    If you didn't request a password reset, you can safely ignore this email.
                    Your password will not be changed.
                  </td>
                </tr>
              </table>
            </div>

            <p style="font-size:13px; color:#9ca3af; margin:0; line-height:1.6;">
              If the button doesn't work, copy and paste this link into your browser:<br>
              <a href="{{ url('app_reset_password', {token: resetToken.token}) }}"
                 style="color:#1a1a2e; font-size:12px; word-break:break-all;">
                {{ url('app_reset_password', {token: resetToken.token}) }}
              </a>
            </p>

          </td>
        </tr>

        <tr>
          <td style="background:#f8f7f4; padding:20px 32px; border-top:1px solid #e5e7eb;">
            <p style="font-size:12px; font-weight:700; color:#374151; margin:0 0 12px; text-transform:uppercase; letter-spacing:0.5px;">
              What's next?
            </p>
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td style="width:33%; text-align:center; padding:0 8px;">
                  <div style="width:28px; height:28px; background:#1a1a2e; border-radius:50%;
                              margin:0 auto 6px; line-height:28px; text-align:center;">
                    <span style="color:white; font-size:12px; font-weight:700;">1</span>
                  </div>
                  <p style="font-size:12px; color:#6b7280; margin:0; line-height:1.4;">Click the button above</p>
                </td>
                <td style="width:33%; text-align:center; padding:0 8px;">
                  <div style="width:28px; height:28px; background:#1a1a2e; border-radius:50%;
                              margin:0 auto 6px; line-height:28px; text-align:center;">
                    <span style="color:white; font-size:12px; font-weight:700;">2</span>
                  </div>
                  <p style="font-size:12px; color:#6b7280; margin:0; line-height:1.4;">Choose a new password</p>
                </td>
                <td style="width:33%; text-align:center; padding:0 8px;">
                  <div style="width:28px; height:28px; background:#1a1a2e; border-radius:50%;
                              margin:0 auto 6px; line-height:28px; text-align:center;">
                    <span style="color:white; font-size:12px; font-weight:700;">3</span>
                  </div>
                  <p style="font-size:12px; color:#6b7280; margin:0; line-height:1.4;">Sign in to your account</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <tr>
          <td style="border-top:1px solid #e5e7eb; padding:16px 32px;">
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td style="font-size:12px; color:#9ca3af;">© {{ 'now'|date('Y') }} Event Management. All rights reserved.</td>
                <td align="right" style="font-size:12px; color:#9ca3af;">Do not reply to this email</td>
              </tr>
            </table>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>

</body>
