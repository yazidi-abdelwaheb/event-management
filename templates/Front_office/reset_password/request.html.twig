{% extends 'Front_office/base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .reset-page {
        min-height: 100vh;
        background: #f8f7f4;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .reset-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        padding: 2rem;
    }

    .reset-logo {
        width: 48px;
        height: 48px;
        background: #1a1a2e;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .reset-title {
        font-size: 22px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 4px;
    }

    .reset-subtitle {
        font-size: 14px;
        color: #6b7280;
        margin: 0;
    }

    

    .btn-reset {
        background: #1a1a2e !important;
        border: none !important;
        border-radius: 8px !important;
        font-size: 15px !important;
        font-weight: 600 !important;
        letter-spacing: 0.3px;
        padding: 11px !important;
        transition: opacity 0.2s !important;
    }

    .btn-reset:hover { opacity: 0.85; }

    .back-link {
        font-size: 13px;
        color: #1a1a2e;
        font-weight: 600;
        text-decoration: none;
    }

    .back-link:hover { text-decoration: underline; color: #1a1a2e; }

    .info-box {
        background: #f0f9ff;
        border: 1px solid #bae6fd;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #0369a1;
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }
</style>
{% endblock %}

{% block body %}
<div class="reset-page">
  <div class="w-100 px-3" style="max-width: 420px;">

    
    <div class="text-center mb-4">
      <div class="reset-logo mb-3">
        <i class="bi bi-shield-lock-fill text-white" style="font-size: 20px;"></i>
      </div>
      <h1 class="reset-title">Forgot your password?</h1>
      <p class="reset-subtitle">No worries, we'll send you a link to reset your password.</p>
    </div>

    
    <div class="reset-card">

      
      {% for flash_error in app.flashes('reset_password_error') %}
        <div class="d-flex align-items-center gap-2 mb-3 py-2 px-3"
             style="background:#fef2f2; border:1px solid #fecaca; border-radius:8px; font-size:13px; color:#991b1b;">
          <i class="bi bi-exclamation-circle-fill" style="color:#dc2626; font-size:14px;"></i>
          {{ flash_error }}
        </div>
      {% endfor %}

      
      <div class="info-box mb-4">
        <i class="bi bi-info-circle-fill" style="font-size:15px; flex-shrink:0; margin-top:1px;"></i>
        <span>Enter your email address and we'll send you a link to reset your password.</span>
      </div>

      {{ form_start(requestForm) }}

        
        <div class="mb-4">
          {{ form_label(requestForm.email) }}
          <div class="input-group">
            <span class="input-group-text">
              <i class="bi bi-envelope" style="font-size:14px;"></i>
            </span>
            {{ form_widget(requestForm.email, {
              'attr': {
                'class': 'form-control',
                'placeholder': 'vous@exemple.com'
              }
            }) }}
          </div>
          {{ form_errors(requestForm.email) }}
        </div>

       
        <div class="d-grid mb-3">
          <button type="submit" class="btn btn-primary btn-reset text-white">
            <i class="bi bi-send me-2" style="font-size:13px;"></i>
            Send Password Reset Link
          </button>
        </div>

      {{ form_end(requestForm) }}

      
      <div class="text-center">
        <a href="{{ path('app_login') }}" class="back-link">
          <i class="bi bi-arrow-left me-1" style="font-size:12px;"></i>
          Back to Sign In
        </a>
      </div>

    </div>
  </div>
</div>
{% endblock %}