
<style>
 .event-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        transition: transform 0.2s;
    }
    .event-card:hover { transform: translateY(-3px); }
    .event-card.featured { border: 2px solid #1a1a2e; }

    .event-thumb {
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .event-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .event-price {
        position: absolute;
        top: 12px;
        right: 12px;
        background: white;
        color: #1a1a2e;
        font-size: 12px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .featured-banner {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: #1a1a2e;
        color: white;
        font-size: 11px;
        font-weight: 700;
        text-align: center;
        padding: 5px;
    }

    .btn-reserve {
        display: block;
        text-align: center;
        background: #1a1a2e;
        color: white !important;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        padding: 9px;
        border-radius: 8px;
        transition: opacity 0.2s;
    }
    .btn-reserve:hover { opacity: 0.85; }


</style>


<div class="col-md-4 ">
                <div class="event-card">
                <div class="event-thumb " style="background:#1a1a2e;">
                    <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}" class="img-fluid" style="max-width:100%; max-height:100%; object-fit:cover; border-radius:8px;">
                    <span class="event-badge" style="background:#EAF3DE; color:#3B6D11;">{{ event.category }}</span>
                    <span class="event-price {{ event.price == 0 ? 'badge bg-warning fw-bold' : '' }} "> {{ event.price == 0 ? 'Free' : event.price | number_format(2, '.', ' ') ~ " TND" }}</span>
                </div>
                <div style="padding:1rem;">
                    <p style="font-size:15px; font-weight:700; color:#1a1a2e; margin:0 0 8px;">
                    {{ event.title }}
                    </p>
                    <div class="meta-row">
                    <i class="bi bi-calendar3" style="font-size:12px; color:#9ca3af;"></i>
                    <span class="meta-text">{{ event.start_date_time|date('D m M Y · H:i') }}</span>
                    </div>
                    <div class="meta-row mb-3">
                    <i class="bi bi-geo-alt" style="font-size:12px; color:#9ca3af;"></i>
                    <span class="meta-text">{{ event.location }}</span>
                    </div>
                    <a href="#" class="btn-reserve">Reserve</a>
                </div>
            </div>
</div>