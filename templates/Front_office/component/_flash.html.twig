<style>
@keyframes shrink {
    from { width: 100%; }
    to   { width: 0%; }
}
.toast-flash { animation: slideIn 0.3s ease forwards; }
@keyframes slideIn {
    from { transform: translateX(110%); opacity: 0; }
    to   { transform: translateX(0);    opacity: 1; }
}
</style>

<div class="toast-container position-fixed bottom-0 right-0 p-4" style="z-index: 9999;">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            {% set config = {
                'success': { 'bg': '#166534', 'icon': 'bi-check-circle-fill', 'title': 'Succès' },
                'danger':  { 'bg': '#991b1b', 'icon': 'bi-x-circle-fill',     'title': 'Erreur' },
                'warning': { 'bg': '#92400e', 'icon': 'bi-exclamation-triangle-fill', 'title': 'Attention' },
                'info':    { 'bg': '#1e3a5f', 'icon': 'bi-info-circle-fill',   'title': 'Information' },
                'verify_email_error': { 'bg': '#991b1b', 'icon': 'bi-envelope-x-fill', 'title': 'Email invalide' }
            } %}
            {% set c = config[label] ?? { 'bg': '#1a1a2e', 'icon': 'bi-bell-fill', 'title': 'Notification' } %}

            <div class="toast-flash toast show mb-3 border-0 overflow-hidden"
                 role="alert"
                 style="min-width: 320px; border-radius: 12px; background: {{ c.bg }};">

               

                <div class="d-flex align-items-center px-3 py-2"
                     style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <i class="bi {{ c.icon }} me-2" style="color:white; font-size:14px;"></i>
                    <span style="color:white; font-size:13px; font-weight:600;">{{ c.title }}</span>
                    <button type="button" class="btn-close btn-close-white ms-auto"
                            data-bs-dismiss="toast" style="font-size:11px;"></button>
                </div>

                <div class="toast-body" style="color:rgba(255,255,255,0.9); font-size:14px; line-height:1.5;">
                    {{ message }}
                </div>
            </div>
        {% endfor %}
    {% endfor %}
</div>