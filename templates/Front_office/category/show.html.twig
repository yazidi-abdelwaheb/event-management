{% extends 'Front_office/base.html.twig' %}

{% block title %}{{ category.label }} — Event Management{% endblock %}

{% block body %}


<style>
    .event-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        transition: transform 0.2s;
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .event-card:hover { transform: translateY(-3px); }

    .event-thumb {
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
    }

    .event-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .event-price {
        position: absolute;
        top: 12px;
        right: 12px;
        background: white;
        color: #1a1a2e;
        font-size: 12px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .featured-banner {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        background: #1a1a2e;
        color: white;
        font-size: 11px;
        font-weight: 700;
        text-align: center;
        padding: 5px;
    }

    .btn-reserve {
        display: block;
        text-align: center;
        background: #1a1a2e;
        color: white !important;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        padding: 9px;
        border-radius: 8px;
        transition: opacity 0.2s;
    }
    .btn-reserve:hover { opacity: 0.85; }

    .meta-row {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 4px;
    }
    .meta-text {
        font-size: 12px;
        color: #6b7280;
        margin: 0;
    }

    .category-hero {
        background: #1a1a2e;
        padding: 3.5rem 1.5rem;
        position: relative;
        overflow: hidden;
    }

    .category-hero-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.18;
    }

    .stat-pill {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 20px;
        padding: 6px 16px;
        font-size: 13px;
        color: rgba(255,255,255,0.85);
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .breadcrumb-item a {
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 13px;
    }
    .breadcrumb-item a:hover { color: white; }
    .breadcrumb-item.active { color: rgba(255,255,255,0.9); font-size: 13px; }
    .breadcrumb-divider { color: rgba(255,255,255,0.4); }

    .filter-btn {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 7px 16px;
        font-size: 13px;
        font-weight: 500;
        color: #374151;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }
    .filter-btn:hover, .filter-btn.active {
        background: #1a1a2e;
        color: white;
        border-color: #1a1a2e;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #6b7280;
    }
</style>




<section class="category-hero">

    {% if category.image %}
        <img src="{{ asset('uploads/categories/' ~ category.image) }}"
             alt="{{ category.label }}"
             class="category-hero-img">
    {% endif %}

    <div class="container" style="position:relative; z-index:1;">

        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb" style="background:none; padding:0; margin:0;">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_home_page') }}">
                        <i class="bi bi-house me-1" style="font-size:12px;"></i>Accueil
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a href="#">Catégories</a>
                </li>
                <li class="breadcrumb-item active">{{ category.label }}</li>
            </ol>
        </nav>

        <div class="d-flex align-items-center gap-4 flex-wrap">

            <div style="width:80px; height:80px; border-radius:16px; background:rgba(255,255,255,0.15);
                        border:2px solid rgba(255,255,255,0.25);
                        display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                {% if category.image %}
                    <img src="{{ asset('uploads/categories/' ~ category.image) }}"
                         alt="{{ category.label }}"
                         style="width:100%; height:100%; object-fit:cover; border-radius:14px;">
                {% else %}
                    <i class="bi bi-grid-fill" style="font-size:32px; color:white;"></i>
                {% endif %}
            </div>

            <div>
                <h1 style="color:white; font-size:32px; font-weight:700; margin:0 0 8px;">
                    {{ category.label }}
                </h1>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="stat-pill">
                        <i class="bi bi-calendar3" style="font-size:12px;"></i>
                        {{ category.events|length }} événement{{ category.events|length > 1 ? 's' : '' }}
                    </span>
                    
                </div>
            </div>

        </div>
    </div>
</section>

<section style="padding:3rem 1.5rem; background:#f8f7f4; min-height:400px;">
  <div class="container">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
      <div>
        <h2 style="font-size:20px; font-weight:700; color:#1a1a2e; margin:0 0 4px;">
          Événements dans "{{ category.label }}"
        </h2>
        <p style="font-size:13px; color:#6b7280; margin:0;">
          {{ category.events|length }} résultat{{ category.events|length > 1 ? 's' : '' }} trouvé{{ category.events|length > 1 ? 's' : '' }}
        </p>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <a href="?sort=date" class="filter-btn {{ app.request.query.get('sort') == 'date' ? 'active' : '' }}">
          <i class="bi bi-calendar3 me-1" style="font-size:11px;"></i>Par date
        </a>
        <a href="?sort=price" class="filter-btn {{ app.request.query.get('sort') == 'price' ? 'active' : '' }}">
          <i class="bi bi-tag me-1" style="font-size:11px;"></i>Par prix
        </a>
        <a href="?sort=free" class="filter-btn {{ app.request.query.get('sort') == 'free' ? 'active' : '' }}">
          <i class="bi bi-gift me-1" style="font-size:11px;"></i>Gratuits
        </a>
      </div>
    </div>

    {% set events = category.events %}

    {% if events|length > 0 %}
        <div class="row g-4">
            {% for event in events %}
                {% include 'Front_office/component/_eventCard.html.twig' with { event: event } %}
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <div style="width:80px; height:80px; background:#e5e7eb; border-radius:50%;
                        display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
                <i class="bi bi-calendar-x" style="font-size:36px; color:#9ca3af;"></i>
            </div>
            <h3 style="font-size:18px; font-weight:600; color:#374151; margin:0 0 8px;">
                Aucun événement disponible
            </h3>
            <p style="font-size:14px; color:#6b7280; margin:0 0 1.5rem;">
                Il n'y a pas encore d'événements dans la catégorie "{{ category.label }}".
            </p>
            <a href="{{ path('app_home_page') }}"
               style="background:#1a1a2e; color:white; text-decoration:none; font-size:14px;
                      font-weight:600; padding:10px 24px; border-radius:8px; display:inline-block;">
                Voir toutes les catégories
            </a>
        </div>
    {% endif %}

  </div>
</section>



{% endblock %}