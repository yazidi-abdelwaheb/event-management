{% extends 'Front_office/base.html.twig' %}

{% block title %}Event Management - Contact{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .contact-hero {
        background: #1a1a2e;
        padding: 3.5rem 1.5rem;
        text-align: center;
    }
    .info-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 1.5rem;
        text-align: center;
        height: 100%;
        transition: transform 0.2s;
    }
    .info-card:hover { transform: translateY(-2px); }
    .info-icon {
        width: 52px; height: 52px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1rem;
    }
    .contact-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 2rem;
    }
    .form-label {
        font-size: 13px !important;
        font-weight: 600 !important;
        color: #374151 !important;
        margin-bottom: 6px !important;
    }
    .input-group-text {
        background: #fafafa !important;
        border-color: #e5e7eb !important;
        color: #9ca3af !important;
    }
    .form-control, .form-select {
        background: #fafafa !important;
        border-color: #e5e7eb !important;
        font-size: 14px !important;
        color: #111827 !important;
        border-left: none !important;
    }
    .form-control:focus, .form-select:focus {
        border-color: #1a1a2e !important;
        box-shadow: none !important;
        background: #fff !important;
    }
    .input-group:focus-within .input-group-text { border-color: #1a1a2e !important; }
    textarea.form-control {
        border-left: 1px solid #e5e7eb !important;
        resize: vertical;
    }
    textarea.form-control:focus { border-color: #1a1a2e !important; }
    .btn-send {
        background: #1a1a2e !important;
        border: none !important;
        border-radius: 8px !important;
        font-size: 15px !important;
        font-weight: 600 !important;
        padding: 12px !important;
        transition: opacity 0.2s !important;
    }
    .btn-send:hover { opacity: 0.85; }
    .map-wrapper {
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #e5e7eb;
        height: 280px;
    }
    .social-link {
        width: 40px; height: 40px;
        background: #f8f7f4;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        text-decoration: none;
        color: #374151;
        font-size: 15px;
        transition: all 0.2s;
    }
    .social-link:hover { background: #1a1a2e; color: white; border-color: #1a1a2e; }
   
</style>
{% endblock %}

{% block body %}
<div style="background:#f8f7f4; min-height:100vh;">


    <section class="contact-hero">
        <div class="container">
            <div style="width:100px; height:100px; background:rgba(255,255,255,0.1);
                        border-radius:16px; display:flex; align-items:center;
                        justify-content:center; margin:0 auto 1.5rem;">
                <image src="{{ asset('logo.png') }}" width="100%" height="100%" alt="Logo Event Management Platform">
            </div>
            <h1 style="color:white; font-size:32px; font-weight:700; margin:0 0 8px;">
                Get in Touch
            </h1>
            <p style="color:rgba(255,255,255,0.65); font-size:15px; max-width:500px; margin:0 auto; line-height:1.7;">
                Have a question or suggestion? Our team is here to help and will get back to you as soon as possible.
            </p>
        </div>
    </section>

    <section style="padding:3rem 1.5rem;">
        <div class="container">

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon" style="background:#EAF3DE;">
                            <i class="bi bi-envelope-fill" style="font-size:20px; color:#3B6D11;"></i>
                        </div>
                        <p style="font-size:14px; font-weight:700; color:#1a1a2e; margin:0 0 4px;">Email</p>
                        <p style="font-size:13px; color:#6b7280; margin:0 0 8px;">contact@eventmanage.com</p>
                        <a href="mailto:contact@eventmanage.com"
                           style="font-size:12px; color:#1a1a2e; font-weight:600; text-decoration:none;">
                            Send an email →
                        </a>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon" style="background:#EEEDFE;">
                            <i class="bi bi-telephone-fill" style="font-size:20px; color:#534AB7;"></i>
                        </div>
                        <p style="font-size:14px; font-weight:700; color:#1a1a2e; margin:0 0 4px;">Phone</p>
                        <p style="font-size:13px; color:#6b7280; margin:0 0 4px;">+216 71 XXX XXX</p>
                        <p style="font-size:12px; color:#9ca3af; margin:0;">Mon–Fri · 09:00–18:00</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon" style="background:#FAEEDA;">
                            <i class="bi bi-geo-alt-fill" style="font-size:20px; color:#854F0B;"></i>
                        </div>
                        <p style="font-size:14px; font-weight:700; color:#1a1a2e; margin:0 0 4px;">Address</p>
                        <p style="font-size:13px; color:#6b7280; margin:0 0 8px;">Lac 2, Tunis, Tunisia</p>
                        <a href="https://maps.google.com" target="_blank"
                           style="font-size:12px; color:#1a1a2e; font-weight:600; text-decoration:none;">
                            View on map →
                        </a>
                    </div>
                </div>
            </div>

            <div class="row g-4">

                <div class="col-lg-7">
                    <div class="contact-card">
                        <h2 style="font-size:18px; font-weight:700; color:#1a1a2e; margin:0 0 4px;">
                            Send us a Message
                        </h2>
                        <p style="font-size:13px; color:#6b7280; margin:0 0 1.5rem;">
                            Fill out the form and we'll get back to you within 24 hours.
                        </p>

                        <form method="post">
                            <div class="row g-3 mb-3">
                                <div class="col-sm-6">
                                    <label class="form-label">First Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-person" style="font-size:14px;"></i>
                                        </span>
                                        <input type="text" class="form-control" name="first_name"
                                               placeholder="Your first name" required>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Last Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-person" style="font-size:14px;"></i>
                                        </span>
                                        <input type="text" class="form-control" name="last_name"
                                               placeholder="Your last name" required>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-envelope" style="font-size:14px;"></i>
                                    </span>
                                    <input type="email" class="form-control" name="email"
                                           placeholder="you@example.com" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Subject</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-chat-dots" style="font-size:14px;"></i>
                                    </span>
                                    <select class="form-select" style="border-left:none !important;" name="subject">
                                        <option value="">Choose a subject</option>
                                        <option>Event Booking</option>
                                        <option>Technical Issue</option>
                                        <option>Partnership / Organizing</option>
                                        <option>Refund Request</option>
                                        <option>Other</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Message</label>
                                <textarea class="form-control"
                                        name="message"
                                        rows="5"
                                        placeholder="Describe your request in detail..."
                                        required></textarea>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-send text-white">
                                    <i class="bi bi-send me-2" style="font-size:13px;"></i>
                                    Send Message
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="col-lg-5 d-flex flex-column gap-3">

                    <div class="map-wrapper">
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3194.0!2d10.2!3d36.8!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzbCsDQ4JzAwLjAiTiAxMMKwMTInMDAuMCJF!5e0!3m2!1sen!2stn!4v1234567890"
                            width="100%" height="100%"
                            style="border:0; display:block;"
                            allowfullscreen loading="lazy">
                        </iframe>
                    </div>

                    <div class="contact-card" style="padding:1.25rem;">
                        <p style="font-size:14px; font-weight:700; color:#1a1a2e; margin:0 0 1rem;">
                            <i class="bi bi-clock me-2"></i>Opening Hours
                        </p>
                        <table style="width:100%; font-size:13px;">
                            <tr>
                                <td style="color:#6b7280; padding:4px 0;">Monday – Friday</td>
                                <td style="text-align:right; font-weight:600; color:#1a1a2e; padding:4px 0;">09:00 – 18:00</td>
                            </tr>
                            <tr>
                                <td style="color:#6b7280; padding:4px 0;">Saturday</td>
                                <td style="text-align:right; font-weight:600; color:#1a1a2e; padding:4px 0;">09:00 – 13:00</td>
                            </tr>
                            <tr>
                                <td style="color:#6b7280; padding:4px 0;">Sunday</td>
                                <td style="text-align:right; font-weight:600; color:#dc2626; padding:4px 0;">Closed</td>
                            </tr>
                        </table>
                    </div>

                    <div class="contact-card" style="padding:1.25rem;">
                        <p style="font-size:14px; font-weight:700; color:#1a1a2e; margin:0 0 1rem;">
                            <i class="bi bi-share me-2"></i>Follow Us
                        </p>
                        <div class="d-flex gap-2 flex-wrap">
                            <a href="#" class="social-link" title="Facebook">
                                <i class="bi bi-facebook"></i>
                            </a>
                            <a href="#" class="social-link" title="Instagram">
                                <i class="bi bi-instagram"></i>
                            </a>
                            <a href="#" class="social-link" title="LinkedIn">
                                <i class="bi bi-linkedin"></i>
                            </a>
                            <a href="#" class="social-link" title="Twitter/X">
                                <i class="bi bi-twitter-x"></i>
                            </a>
                            <a href="#" class="social-link" title="YouTube">
                                <i class="bi bi-youtube"></i>
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}