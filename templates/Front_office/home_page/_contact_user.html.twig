{# templates/emails/contact_user.html.twig #}

<div style="max-width:600px;margin:auto;font-family:Arial;background:#f9fafb;padding:20px;">
    
    <div style="background:#1a1a2e;color:white;padding:20px;border-radius:10px 10px 0 0;">
        <h2>Event Management</h2>
    </div>

    <div style="background:#16a34a;color:white;padding:10px;font-weight:bold;">
        ✔ Message Received
    </div>

    <div style="background:white;padding:20px;border-radius:0 0 10px 10px;">
        
        <h3>hey, {{ contact.firstName }} 👋</h3>

        <p>
            Thank you for contacting us. Your message has been successfully sent to our team.
        </p>

        <p>
            Our team will review your request and respond as soon as possible.
        </p>

        <div style="margin-top:20px;padding:15px;background:#f3f4f6;border-radius:8px;">
            <strong>Your Message:</strong><br>
            {{ contact.message }}
        </div>

        <p style="margin-top:20px;color:#6b7280;">
            This is an automatic confirmation email.
        </p>

    </div>
    <div>
          <td style="border-top:1px solid #e5e7eb; padding:16px 32px;">
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td style="font-size:12px; color:#9ca3af;">© {{ 'now'|date('Y') }} Event Management. All rights reserved.</td>
                <td align="right" style="font-size:12px; color:#9ca3af;">Do not reply to this email</td>
              </tr>
            </table>
          </td>
        </div>
</div>