
<div style="margin:0; padding:0; background:#f4f4f5; font-family: Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5; padding: 40px 16px;">
    <tr><td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:12px; overflow:hidden; border: 1px solid #e5e7eb;">

        
        <tr>
          <td style="background:#1a1a2e; padding: 24px 32px;">
            <span style="color:white; font-size:16px; font-weight:bold;">Event Management</span>
          </td>
        </tr>

        
        <tr>
          <td style="padding: 40px 32px 32px;">

           
            <div style="width:56px; height:56px; background:#EAF3DE; border-radius:50%; margin-bottom:24px; display:flex; align-items:center; justify-content:center;">
              ✅
            </div>

            <h1 style="font-size:22px; font-weight:600; color:#111827; margin:0 0 8px;">
                Confirm Your Email Address
            </h1>
            <p style="font-size:15px; color:#6b7280; margin:0 0 28px; line-height:1.6;">
              Thank you for signing up! Click the button below to verify your address and activate your account.
            </p>

            <a href="{{ signedUrl|raw }}"
               style="display:inline-block; background:#1a1a2e; color:white; text-decoration:none;
                      font-size:15px; font-weight:600; padding:14px 32px; border-radius:8px; margin-bottom:28px;">
              Confirm my email →
            </a>

            <div style="background:#f9fafb; border-radius:8px; padding:12px 16px; margin-bottom:28px;">
              <p style="font-size:13px; color:#6b7280; margin:0; line-height:1.5;">
                ⏰ This link expires in
                <strong style="color:#111827;">
                  {{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}
                </strong>.
                If you did not create this account, please ignore this email.
              </p>
            </div>

            <p style="font-size:13px; color:#9ca3af; margin:0; line-height:1.6;">
            If the button doesn't work, copy this link:<br>
              <span style="color:#3b82f6; font-size:12px; word-break:break-all;">{{ signedUrl|raw }}</span>
            </p>

          </td>
        </tr>

        <tr>
          <td style="border-top: 1px solid #f3f4f6; padding: 20px 32px;">
            <table width="100%"><tr>
              <td style="font-size:12px; color:#9ca3af;">© {{ "now"|date("Y") }} Event Management. All rights reserved.</td>
              <td align="right" style="font-size:12px; color:#9ca3af;">Do not reply to this email</td>
            </tr></table>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>

</div>