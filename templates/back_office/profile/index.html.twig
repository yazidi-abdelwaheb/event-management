{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
<div class="container py-4">

    {# ── Alerts ── #}
    {% if error %}
        <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 mb-4" role="alert">
            <i class="fa fa-circle-exclamation"></i> {{ error }}
        </div>
    {% endif %}
    {% if success %}
        <div class="alert alert-success d-flex align-items-center gap-2 rounded-3 mb-4" role="alert">
            <i class="fa fa-circle-check"></i> {{ success }}
        </div>
    {% endif %}

    {# ── Header profil ── #}
    <div class="rounded-4 p-4 mb-4 d-flex align-items-center gap-4"
         style="background: linear-gradient(135deg, #2563eb, #7c3aed);">

       
        {% if user.avatar %}
            <img src="/uploads/avatars/{{ user.avatar }}"
                 class="rounded-circle flex-shrink-0"
                 style="width:80px; height:80px; object-fit:cover; border: 3px solid rgba(255,255,255,0.4);">
        {% else %}
            <div class="rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center fw-bold"
                 style="width:80px; height:80px; font-size:28px; color:#fff;
                        background: rgba(255,255,255,0.2); border: 3px solid rgba(255,255,255,0.4);">
                {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
            </div>
        {% endif %}

        {# Infos #}
        <div class="flex-grow-1">
            <h2 class="fw-bold mb-1" style="color:#fff; font-size:20px;">
                {{ user.firstName }} {{ user.lastName }}
            </h2>
            <div class="mb-2" style="color: rgba(255,255,255,0.7); font-size:13px;">
                <i class="fa fa-envelope me-1"></i> {{ user.email }}
            </div>
            <span class="badge rounded-pill px-3 py-1"
                  style="background: rgba(255,255,255,0.2); color:#fff; font-size:11px;">
                {{ user.role }}
            </span>
        </div>

        {# Date #}
        <div class="text-end d-none d-md-block" style="color: rgba(255,255,255,0.6); font-size:12px;">
            <i class="fa fa-calendar me-1"></i>Member since<br>
            <strong style="color:#fff;">{{ user.createdAt|date('d/m/Y') }}</strong>
        </div>
    </div>

    
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h3 class="fw-bold mb-4 d-flex align-items-center gap-2" style="font-size:15px; color:#111827;">
                <span class="d-flex align-items-center justify-content-center rounded-3"
                      style="width:32px; height:32px; background:#eff6ff;">
                    <i class="fa fa-user" style="color:#2563eb; font-size:13px;"></i>
                </span>
                personal information
            </h3>

            <form method="post">
                <input type="hidden" name="section" value="info">

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted" style="font-size:12px; text-transform:uppercase; letter-spacing:.04em;">
                            First name
                        </label>
                        <input type="text" name="first_name" value="{{ user.firstName }}"
                               class="form-control rounded-3" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted" style="font-size:12px; text-transform:uppercase; letter-spacing:.04em;">
                            Last name
                        </label>
                        <input type="text" name="last_name" value="{{ user.lastName }}"
                               class="form-control rounded-3" required>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold text-muted" style="font-size:12px; text-transform:uppercase; letter-spacing:.04em;">
                        Email
                    </label>
                    <input type="email" name="email" value="{{ user.email }}"
                           class="form-control rounded-3" required>
                </div>

                <button type="submit" class="btn btn-primary rounded-3 px-4">
                    <i class="fa fa-floppy-disk me-2"></i> Save changes
                </button>
            </form>
        </div>
    </div>

    
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h3 class="fw-bold mb-4 d-flex align-items-center gap-2" style="font-size:15px; color:#111827;">
                <span class="d-flex align-items-center justify-content-center rounded-3"
                      style="width:32px; height:32px; background:#f5f3ff;">
                    <i class="fa fa-image" style="color:#7c3aed; font-size:13px;"></i>
                </span>
                Avatar
            </h3>

            <form method="post" enctype="multipart/form-data">
                <input type="hidden" name="section" value="avatar">

                <div class="d-flex align-items-center gap-4">
                    {% if user.avatar %}
                        <img src="/uploads/avatars/{{ user.avatar }}"
                             class="rounded-circle flex-shrink-0"
                             style="width:64px; height:64px; object-fit:cover; border:2px solid #e5e7eb;">
                    {% else %}
                        <div class="rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center fw-bold"
                             style="width:64px; height:64px; font-size:22px; color:#fff;
                                    background: linear-gradient(135deg, #2563eb, #7c3aed);">
                            {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                        </div>
                    {% endif %}

                    <div class="flex-grow-1">
                        <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp"
                               class="form-control rounded-3">
                        <div class="form-text">JPG, PNG ou WEBP · Max 2 Mo</div>
                    </div>

                    <button type="submit" class="btn rounded-3 px-4 text-white flex-shrink-0"
                            style="background:#7c3aed;">
                        <i class="fa fa-upload me-2"></i> Set new avatar
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# ── Mot de passe ── #}
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h3 class="fw-bold mb-4 d-flex align-items-center gap-2" style="font-size:15px; color:#111827;">
                <span class="d-flex align-items-center justify-content-center rounded-3"
                      style="width:32px; height:32px; background:#fff7ed;">
                    <i class="fa fa-lock" style="color:#ea580c; font-size:13px;"></i>
                </span>
                Update password
            </h3>

            <form method="post">
                <input type="hidden" name="section" value="password">

                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted" style="font-size:12px; text-transform:uppercase; letter-spacing:.04em;">
                        Actual password
                    </label>
                    <input type="password" name="current_password"
                           class="form-control rounded-3" required>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted" style="font-size:12px; text-transform:uppercase; letter-spacing:.04em;">
                           New password
                        </label>
                        <input type="password" name="new_password" minlength="8"
                               class="form-control rounded-3" required>
                        <div class="form-text">Minimum 8 caractères</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted" style="font-size:12px; text-transform:uppercase; letter-spacing:.04em;">
                            Confirm new password
                        </label>
                        <input type="password" name="confirm_password"
                               class="form-control rounded-3" required>
                    </div>
                </div>

                <button type="submit" class="btn rounded-3 px-4 text-white"
                        style="background:#ea580c;">
                    <i class="fa fa-shield me-2"></i> Update password
                </button>
            </form>
        </div>
    </div>

</div>
{% endblock %}