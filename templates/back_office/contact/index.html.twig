{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
<div class="container-fluid py-3" style="background-color: #f6f8fc; min-vh-100;">
    
    {# 1. En-tête avec Statistiques Rapides #}
    <div class="d-flex align-items-center justify-content-between mb-4 px-2">
        <h2 class="h4 fw-bold text-dark mb-0">Gestion des Messages</h2>
        <div class="d-flex gap-2">
            <span class="badge rounded-pill bg-primary px-3 py-2 shadow-sm">
                {{ messages|length }} Messages au total
            </span>
        </div>
    </div>

    <div class="row g-3">
        {# 2. Menu Latéral (Sidebar) #}
        <div class="col-lg-2 d-none d-lg-block">
            <div class="nav flex-column nav-pills shadow-sm bg-white rounded-4 p-2 border">
                <a class="nav-link active rounded-3 mb-1" href="#" style="background-color: #d3e3fd; color: #041e49;">
                    <i class="bi bi-inbox-fill me-2"></i> Boîte de réception
                </a>
                <a class="nav-link text-dark rounded-3 mb-1" href="#">
                    <i class="bi bi-star me-2"></i> Suivis
                </a>
                <a class="nav-link text-dark rounded-3 mb-1" href="#">
                    <i class="bi bi-trash me-2"></i> Corbeille
                </a>
                <hr class="mx-3 text-muted">
                <div class="px-3 small fw-bold text-muted text-uppercase" style="font-size: 0.7rem;">Labels</div>
                <a class="nav-link text-dark rounded-3" href="#">
                    <span class="badge bg-info me-2"> </span> Support
                </a>
            </div>
        </div>

        {# 3. La Liste des Messages #}
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                
                {# Barre d'outils style Gmail #}
                <div class="card-header bg-white border-bottom p-2 d-flex align-items-center justify-content-between sticky-top">
                    <div class="d-flex align-items-center gap-1">
                        <div class="px-2">
                            <input type="checkbox" class="form-check-input">
                        </div>
                        <button class="btn btn-light btn-sm rounded-circle shadow-none" title="Actualiser">
                            <i class="bi bi-arrow-clockwise text-muted"></i>
                        </button>
                        <button class="btn btn-light btn-sm rounded-circle shadow-none" title="Marquer comme lu">
                            <i class="bi bi-envelope-open text-muted"></i>
                        </button>
                    </div>
                    
                    <div class="d-flex align-items-center gap-3 pe-2">
                        <small class="text-muted">1-{{ messages|length }} sur {{ messages|length }}</small>
                        <div class="btn-group">
                            <button class="btn btn-outline-light btn-sm text-muted border-0"><i class="bi bi-chevron-left"></i></button>
                            <button class="btn btn-outline-light btn-sm text-muted border-0"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>

                {# Liste des lignes #}
                <div class="list-group list-group-flush">
                    {% for msg in messages %}
                        <div class="list-group-item list-group-item-action d-flex align-items-center border-0 border-bottom px-3 py-2 transition-all" 
                             style="font-size: 0.88rem; {{ not msg.isRead ? 'background-color: #ffffff; font-weight: 700;' : 'background-color: #f8f9fa; opacity: 0.8;' }}">
                            
                            {# Checkbox & Favoris #}
                            <div class="d-flex align-items-center me-3 flex-shrink-0">
                                <input type="checkbox" class="form-check-input me-3 shadow-none">
                                <i class="bi bi-star text-muted opacity-25"></i>
                            </div>

                            {# Expéditeur #}
                            <div class="text-truncate me-3" style="width: 180px; color: #1a1a1a;">
                                {{ msg.firstName }} {{ msg.lastName }}
                            </div>

                            {# Sujet et Aperçu du message #}
                            <div class="flex-grow-1 text-truncate pe-4"  style="cursor: pointer;">
                                <span class="text-dark">{{ msg.subject }}</span>
                                <span class="text-muted fw-normal"> — {{ msg.message|slice(0, 120) }}...</span>
                            </div>

                            {# Date de réception #}
                            <div class="ms-auto text-muted small flex-shrink-0 fw-normal">
                                {{ msg.createdAt|date('d M') }}
                            </div>
                        </div>
                    {% else %}
                        <div class="p-5 text-center bg-white">
                            <div class="mb-3 text-muted opacity-25"><i class="bi bi-inbox fs-1"></i></div>
                            <p class="text-muted mb-0">Aucun message de contact pour le moment.</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
            
            {# Footer discret #}
            <div class="mt-3 text-center">
                <p class="small text-muted">Dernière mise à jour : {{ "now"|date("H:i") }}</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}